meta {
  name: T-Invest — List accounts
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/api/profile/tinkoff/accounts?sandbox=0
  auth: none
}

docs {
  ## T-Invest: список счетов

  Запрашивает у T-Invest `UsersService/GetAccounts` от имени текущего пользователя
  (используя зашифрованный токен из БД) и возвращает список счетов.

  Используется для выбора счёта перед синхронизацией портфеля.
}
